# Эти значения не являются секретами, но должны относиться к проекту владельца.
# Скопируйте файл в studio/.env.local и заполните Project ID.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_API_VERSION=2026-07-15
SANITY_STUDIO_USE_CDN=false
SANITY_STUDIO_PREVIEW_URL=http://localhost:5173
SANITY_STUDIO_PRODUCTION_URL=
SANITY_STUDIO_LEAD_HEALTH_URL=

# Эти переменные попадут в browser bundle Studio. Никогда не добавляйте сюда
# read/write token, пароль, bot token, webhook secret или CRM-ключ.
