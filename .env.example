# URL защищённой серверной функции, принимающей заявки с сайта.
# Не указывайте здесь Telegram Bot API, bot token, chat id или другие секреты.
# Если оставить значение пустым, форма сохранит данные и предложит открыть Telegram вручную.
VITE_LEAD_ENDPOINT=

# Только server/hosting environment. Эти значения нельзя переносить в VITE_, Sanity или Git.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
LEAD_WEBHOOK_SECRET=

# Точные origins через запятую, без wildcard. Пример: https://speaker-one.ru,http://localhost:5173
LEAD_ALLOWED_ORIGINS=http://localhost:5173
# Origins, которым разрешено читать безопасный статус /health (например Studio).
LEAD_STATUS_ALLOWED_ORIGINS=http://localhost:3333
LEAD_TIMEZONE=Asia/Yekaterinburg

# Только для ручного server-side теста scripts/test-lead-endpoint.mjs.
LEAD_TEST_ENDPOINT=

# Публичные параметры Sanity для build-time загрузки published-контента и SEO.
# Любая переменная VITE_* видна в browser bundle — токены здесь запрещены.
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2026-07-15
VITE_SANITY_USE_CDN=true
VITE_ENABLE_VISUAL_EDITING=false

# Только для защищённого server-side preview. Не используйте префикс VITE_.
# Read token должен иметь только право чтения dataset и храниться локально/в secret storage хостинга.
SANITY_API_READ_TOKEN=
SANITY_STUDIO_URL=http://localhost:3333
SANITY_PREVIEW_PORT=5173

# Для локальной разработки можно оставить пустым: preview-server создаст временный ключ
# до перезапуска процесса. Для размещённого preview задайте длинное случайное значение
# только в server environment — оно подписывает HttpOnly preview-session.
SANITY_PREVIEW_SESSION_SECRET=
